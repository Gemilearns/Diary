# ============================================================
# Glass Journal — Environment Variables
# Auth is handled by a separate backend; this service has none.
# ============================================================

# Database — from neon.tech → New Project → connection string
DATABASE_URL=postgresql://user:password@ep-xxxx.neon.tech/glassjournal?sslmode=require

# Backblaze B2 — S3-compatible API
# Get these from https://secure.backblaze.com/app_keys.htm
B2_KEY_ID=
B2_APPLICATION_KEY=
B2_BUCKET_NAME=glass-journal
B2_ENDPOINT=https://s3.us-west-004.backblazeb2.com
B2_REGION=us-west-004

# App
PORT=3000
NODE_ENV=production

# Optional
# STORAGE_DRIVER: "b2" (default) or "local" (writes to ./local-storage/, signed URLs served by /local-blob/:key)
STORAGE_DRIVER=b2
LOCAL_STORAGE_DIR=./local-storage

# Max upload size in bytes. Default 500 MB. Bump for very large videos.
MAX_UPLOAD_BYTES=524288000

# Signed URL expiry in seconds (default 1 hour — B2 max is 7 days)
SIGNED_URL_EXPIRES=3600